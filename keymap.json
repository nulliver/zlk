[
  // ───────────────────────────────────────────────
  // DEBUGGING  (no prefix – F-key layout)
  // ───────────────────────────────────────────────
  {
    "bindings": {
      // Spawn task (pick from list)
      "f4": "task::Spawn",
      // Rerun last task
      "shift-f4": ["task::Rerun", { "reevaluate_context": false }],
      "f5": "debugger::Start", // Start (when not running)
      "shift-f5": "debugger::Stop", // Stop
      "f6": "debugger::StepOver", // Step Over
      "f7": "debugger::StepInto", // Step Into
      "shift-f7": "debugger::StepOut", // Step Out
      "f8": "editor::ToggleBreakpoint", // Toggle breakpoint
      "shift-f8": "editor::EditLogBreakpoint", // Set log / conditional breakpoint
      "super-f8": "debugger::ClearAllBreakpoints", // Delete all breakpoints
      "f9": "editor::GoToDiagnostic", // Next diagnostic
      "shift-f9": "editor::GoToPreviousDiagnostic", // Previous diagnostic
    },
  },
  {
    // When the debugger is actively running, f5 should restart (rerun)
    "context": "Workspace && debugger_running",
    "bindings": {
      "f5": "debugger::Rerun",
      "f6": "debugger::StepOver",
    },
  },
  {
    // When the debugger is paused/stopped at a breakpoint, f5 resumes
    "context": "Workspace && debugger_stopped",
    "bindings": {
      "f5": "debugger::Continue",
      "f6": "debugger::StepOver",
      "f7": "debugger::StepInto",
      "shift-f7": "debugger::StepOut",
    },
  },

  // ───────────────────────────────────────────────
  // DISABLED DEFAULTS
  // ───────────────────────────────────────────────
  {
    "context": "Pane",
    "bindings": {
      "cmd-w": null,
      "cmd-f": null,
      "cmd-r": null,
      "cmd-shift-f": null,
      // Search actions now under super-f
      "cmd-g": null, // search::SelectNextMatch
      "cmd-shift-g": null, // search::SelectPreviousMatch
      "cmd-shift-h": null, // search::ToggleReplace
      "cmd-alt-l": null, // search::ToggleSelection
      "alt-enter": null, // search::SelectAllMatches
      "alt-cmd-c": null, // search::ToggleCaseSensitive
      "alt-cmd-w": null, // search::ToggleWholeWord
      "alt-cmd-x": null, // search::ToggleRegex
      "alt-cmd-f": null, // project_search::ToggleFilters
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-w": null,
      "cmd-f": null,
      "cmd-r": null,
      // Window/panel toggles now under super-w
      "cmd-b": null, // workspace::ToggleLeftDock
      "cmd-alt-b": null, // workspace::ToggleRightDock
      "cmd-j": null, // workspace::ToggleBottomDock
      // Panels now under super-w
      "cmd-shift-e": null, // project_panel::ToggleFocus
      "cmd-shift-b": null, // outline_panel::ToggleFocus
      "ctrl-shift-g": null, // git_panel::ToggleFocus
      "cmd-shift-d": null, // debug_panel::ToggleFocus
      "cmd-shift-m": null, // diagnostics::Deploy
      // Navigate now under super-n
      "cmd-t": null, // project_symbols::Toggle
      "cmd-p": null, // file_finder::Toggle
      "cmd-shift-p": null, // command_palette::Toggle
      // Project search now under super-f /
      "cmd-shift-f": null, // pane::DeploySearch
      // Recent/remote projects now under super-w
      "alt-cmd-o": null, // projects::OpenRecent
      "ctrl-cmd-o": null, // projects::OpenRemote
    },
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-f": null,
      "cmd-e": null,
      "cmd-shift-o": null,
      // Format and organize imports now under super-r
      "cmd-shift-i": null, // editor::Format
      "alt-shift-o": null, // editor::OrganizeImports
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // Hover now under super-j h
      "cmd-k cmd-i": null, // editor::Hover
      // Fold actions now under super-b
      "alt-cmd-[": null, // editor::Fold
      "alt-cmd-]": null, // editor::UnfoldLines
      "cmd-k cmd-l": null, // editor::ToggleFold
      "cmd-k cmd-[": null, // editor::FoldRecursive
      "cmd-k cmd-]": null, // editor::UnfoldRecursive
      "cmd-k cmd-0": null, // editor::FoldAll
      "cmd-k cmd-j": null, // editor::UnfoldAll
      "cmd-k cmd-1": null, // editor::FoldAtLevel_1
      "cmd-k cmd-2": null, // editor::FoldAtLevel_2
      "cmd-k cmd-3": null, // editor::FoldAtLevel_3
      "cmd-k cmd-4": null, // editor::FoldAtLevel_4
      "cmd-k cmd-5": null, // editor::FoldAtLevel_5
      "cmd-k cmd-6": null, // editor::FoldAtLevel_6
      "cmd-k cmd-7": null, // editor::FoldAtLevel_7
      "cmd-k cmd-8": null, // editor::FoldAtLevel_8
      "cmd-k cmd-9": null, // editor::FoldAtLevel_9
      // Code actions now under super-r a
      "cmd-.": null, // editor::ToggleCodeActions
      // Completions now under super-r c
      "ctrl-space": null, // editor::ShowCompletions
      "ctrl-shift-space": null, // editor::ShowWordCompletions
      // Signature help now under super-r h
      "cmd-i": null, // editor::ShowSignatureHelp
    },
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      // Markdown preview now under super-e m / super-e super-m
      "cmd-k v": null, // markdown::OpenPreviewToTheSide
      "cmd-shift-v": null, // markdown::OpenPreview
    },
  },
  {
    "context": "BufferSearchBar",
    "bindings": {
      "cmd-alt-f": null, // search::ToggleReplace
      "cmd-alt-l": null, // search::ToggleSelection
    },
  },
  {
    "context": "ProjectSearchBar",
    "bindings": {
      "cmd-shift-h": null, // search::ToggleReplace
      "alt-cmd-g": null, // search::ToggleRegex
      "alt-cmd-x": null, // search::ToggleRegex
      "cmd-shift-j": null, // project_search::ToggleFilters
    },
  },
  {
    "context": "ProjectSearchView",
    "bindings": {
      "cmd-shift-h": null, // search::ToggleReplace
      "alt-cmd-g": null, // search::ToggleRegex
      "alt-cmd-x": null, // search::ToggleRegex
      "cmd-shift-j": null, // project_search::ToggleFilters
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      // Already listed above — add this one:
      "ctrl-cmd-o": null, // projects::OpenRemote (from_existing_connection: true variant)
    },
  },

  // ───────────────────────────────────────────────
  // super-j  →  JUMP
  // ───────────────────────────────────────────────
  {
    "context": "Editor",
    "bindings": {
      "cmd-j": null, // was "workspace::ToggleBottomDock"
      // Go to Definition
      "super-j d": "editor::GoToDefinition",
      "super-j super-d": "editor::GoToDefinition",
      // Go to Type Definition
      "super-j t": "editor::GoToTypeDefinition",
      "super-j super-t": "editor::GoToTypeDefinition",
      // Go to Implementation
      "super-j i": "editor::GoToImplementation",
      "super-j super-i": "editor::GoToImplementation",
      // Find All References / usages
      "super-j r": "editor::FindAllReferences",
      "super-j super-r": "editor::FindAllReferences",
      // Move to matching / enclosing bracket
      "super-j j": "editor::MoveToEnclosingBracket",
      "super-j super-j": "editor::MoveToEnclosingBracket",
      // Move to start of paragraph / code block
      "super-j s": "editor::MoveToStartOfParagraph",
      "super-j super-s": "editor::MoveToStartOfParagraph",
      // Move to end of paragraph / code block
      "super-j e": "editor::MoveToEndOfParagraph",
      "super-j super-e": "editor::MoveToEndOfParagraph",
      // Hover / show documentation inline
      "super-j h": "editor::Hover",
      "super-j super-h": "editor::Hover",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      // Go Back (navigate history)
      "super-j b": "pane::GoBack",
      "super-j super-b": "pane::GoBack",
      // Go Forward (navigate history)
      "super-j f": "pane::GoForward",
      "super-j super-f": "pane::GoForward",
      // Go to Line
      "super-j l": "go_to_line::Toggle",
      "super-j super-l": "go_to_line::Toggle",
      // Reveal current file in Project Panel
      "super-j p": "pane::RevealInProjectPanel",
      "super-j super-p": "pane::RevealInProjectPanel",
      // Outline floating picker — jump to symbol in current file
      "super-j o": "outline::Toggle",
      "super-j super-o": "outline::Toggle",
    },
  },

  // ───────────────────────────────────────────────
  // super-n  →  NAVIGATE
  // ───────────────────────────────────────────────
  {
    "context": "Workspace",
    "bindings": {
      // File Finder (open file by name)
      "super-n f": "file_finder::Toggle",
      "super-n super-f": "file_finder::Toggle",
      // Project Symbols (go to symbol across project)
      "super-n s": "project_symbols::Toggle",
      "super-n super-s": "project_symbols::Toggle",
      // Project Search (find in files)
      "super-n p": "pane::DeploySearch",
      "super-n super-p": "pane::DeploySearch",
      // Command Palette
      "super-n c": "command_palette::Toggle",
      "super-n super-c": "command_palette::Toggle",
      // Diagnostics (problems panel)
      "super-n d": "diagnostics::Deploy",
      "super-n super-d": "diagnostics::Deploy",
    },
  },

  // ───────────────────────────────────────────────
  // super-r  →  REFACTOR
  // ───────────────────────────────────────────────
  {
    "context": "Editor",
    "bindings": {
      // Rename symbol
      "super-r r": "editor::Rename",
      "super-r super-r": "editor::Rename",
      // Format document
      "super-r f": "editor::Format",
      "super-r super-f": "editor::Format",
      // Organize Imports
      "super-r i": "editor::OrganizeImports",
      "super-r super-i": "editor::OrganizeImports",
      // Code Actions (quick fix / refactor menu)
      "super-r a": "editor::ToggleCodeActions",
      "super-r super-a": "editor::ToggleCodeActions",
      // Show completions (offer)
      "super-r c": "editor::ShowCompletions",
      "super-r super-c": "editor::ShowWordCompletions",
      // Show signature help
      "super-r h": "editor::ShowSignatureHelp",
      "super-r super-h": "editor::ShowSignatureHelp",
    },
  },
  // ───────────────────────────────────────────────
  // super-l  →  LINE
  // ───────────────────────────────────────────────
  {
    "context": "Editor && mode == full",
    "bindings": {
      // Same as default
      "alt-up": "editor::MoveLineUp",
      "alt-down": "editor::MoveLineDown",
      // Duplicate line Down
      "super-l d": "editor::DuplicateLineDown",
      "super-l super-d": "editor::DuplicateLineDown",
      // Delete line
      "super-l x": "editor::DeleteLine",
      "super-l super-x": "editor::DeleteLine",
      // Join lines
      "super-l j": "editor::JoinLines",
      "super-l super-j": "editor::JoinLines",
      // Toggle line comment
      "super-l c": ["editor::ToggleComments", { "advance_downwards": false }],
      "super-l super-c": [
        "editor::ToggleComments",
        { "advance_downwards": false },
      ],
      // Enter empty line Above current line
      "super-l a": "editor::NewlineAbove",
      "super-l super-a": "editor::NewlineAbove",
      // Enter empty line Below current line
      "super-l b": "editor::NewlineBelow",
      "super-l super-b": "editor::NewlineBelow",
    },
  },

  // ───────────────────────────────────────────────
  // super-b  →  BLOCK / SELECTION
  // ───────────────────────────────────────────────
  {
    "context": "Editor",
    "bindings": {
      "super-b": null,
      // Expand selection (larger syntax node)
      "super-b e": "editor::SelectLargerSyntaxNode",
      "super-b super-e": "editor::SelectLargerSyntaxNode",
      // Shrink selection (smaller syntax node)
      "super-b s": "editor::SelectSmallerSyntaxNode",
      "super-b super-s": "editor::SelectSmallerSyntaxNode",
      // Move to matching bracket
      "super-b j": "editor::MoveToEnclosingBracket",
      "super-b super-j": "editor::MoveToEnclosingBracket",
      // Select Next occurrence of word/selection
      "super-b n": ["editor::SelectNext", { "replace_newest": false }],
      "super-b super-n": ["editor::SelectNext", { "replace_newest": false }],
      // Skip current occurrence, move selection to next
      "super-b p": ["editor::SelectNext", { "replace_newest": true }],
      "super-b super-p": ["editor::SelectNext", { "replace_newest": true }],
      // Select All occurrences / matches
      "super-b a": "editor::SelectAllMatches",
      "super-b super-a": "editor::SelectAllMatches",
      // Add cursor above
      "super-b c": ["editor::AddSelectionAbove", { "skip_soft_wrap": true }],
      "super-b super-c": [
        "editor::AddSelectionAbove",
        { "skip_soft_wrap": true },
      ],
      // Add cursor below
      "super-b v": ["editor::AddSelectionBelow", { "skip_soft_wrap": true }],
      "super-b super-v": [
        "editor::AddSelectionBelow",
        { "skip_soft_wrap": true },
      ],

      "super-b f": "editor::ToggleFold",
      "super-b super-f": "editor::ToggleFold",
      "super-b [": "editor::FoldRecursive",
      "super-b super-[": "editor::FoldRecursive",
      "super-b ]": "editor::UnfoldRecursive",
      "super-b super-]": "editor::UnfoldRecursive",
      "super-b super-f super-1": "editor::FoldAtLevel_1",
      "super-b super-f super-2": "editor::FoldAtLevel_2",
      "super-b super-f super-3": "editor::FoldAtLevel_3",
      "super-b super-f super-4": "editor::FoldAtLevel_4",
      "super-b super-f super-5": "editor::FoldAtLevel_5",
      "super-b super-f super-6": "editor::FoldAtLevel_6",
      "super-b super-f super-7": "editor::FoldAtLevel_7",
      "super-b super-f super-8": "editor::FoldAtLevel_8",
      "super-b super-f super-9": "editor::FoldAtLevel_9",
      "super-b super-f super-a": "editor::FoldAll",
      "super-b super-f super-u": "editor::UnfoldAll",
    },
  },

  // ───────────────────────────────────────────────
  // super-f  →  FIND
  // ───────────────────────────────────────────────
  {
    "context": "Pane",
    "bindings": {
      // Show search bar and focus on it
      "super-f f": ["buffer_search::Deploy", { "focus": true }],
      "super-f super-f": ["buffer_search::Deploy", { "focus": true }],
      // Show replace text box
      "super-f r": "buffer_search::DeployReplace",
      "super-f super-r": "buffer_search::DeployReplace",
      // Next / previous match  (n/p — consistent with super-b n/p for selections)
      "super-f n": "search::SelectNextMatch",
      "super-f super-n": "search::SelectNextMatch",
      "super-f p": "search::SelectPreviousMatch", // ← moves DeploySearch elsewhere
      "super-f super-p": "search::SelectPreviousMatch",
      // Select all matches
      "super-f a": "search::SelectAllMatches",
      "super-f super-a": "search::SelectAllMatches",
      // Toggle replace
      "super-f t": "search::ToggleReplace",
      "super-f super-t": "search::ToggleReplace",
      // Toggle search within selection only
      "super-f s": "search::ToggleSelection",
      "super-f super-s": "search::ToggleSelection",
      // Toggles — modifiers for the search itself
      "super-f c": "search::ToggleCaseSensitive",
      "super-f super-c": "search::ToggleCaseSensitive",
      "super-f w": "search::ToggleWholeWord",
      "super-f super-w": "search::ToggleWholeWord",
      "super-f x": "search::ToggleRegex",
      "super-f super-x": "search::ToggleRegex",
      // Toggle symbol outline
      "super-f o": "outline::Toggle",
      "super-f super-o": "outline::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      // Project Search (find in files) — moved from p to slash
      "super-f /": "pane::DeploySearch",
      "super-f super-/": "pane::DeploySearch",
      // Project search filters
      "super-f super-i": "project_search::ToggleFilters",
      "super-f i": "project_search::ToggleFilters",
    },
  },

  // ───────────────────────────────────────────────
  // super-e  →  EDITOR
  // ───────────────────────────────────────────────
  {
    "context": "Workspace",
    "bindings": {
      // Split Right
      "super-e right": "pane::SplitRight",
      // Move focus to pane right
      "super-e super-right": "workspace::ActivatePaneRight",
      // Move pane to the right
      "super-e l": "workspace::SwapPaneRight",
      // Split pane down
      "super-e down": "pane::SplitDown",
      // Move focus to pane below
      "super-e super-down": "workspace::ActivatePaneDown",
      // Move pane down
      "super-e j": "workspace::SwapPaneDown",
      // Split pane left
      "super-e left": "pane::SplitLeft",
      // Move focus to pane left
      "super-e super-left": "workspace::ActivatePaneLeft",
      // Move pane to the left
      "super-e h": "workspace::SwapPaneLeft",
      // Split pane up
      "super-e up": "pane::SplitUp",
      // Move focus to pane above
      "super-e super-up": "workspace::ActivatePaneUp",
      // Move pane up
      "super-e k": "workspace::SwapPaneUp",
      // Pin / unpin tab
      "super-e p": "pane::TogglePinTab",
      "super-e super-p": "pane::TogglePinTab",
      // Next tab
      "super-e n": "pane::ActivateNextItem",
      "super-e super-n": "pane::ActivateNextItem",
      // Previous tab
      "super-e b": "pane::ActivatePreviousItem",
      "super-e super-b": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      // Markdown Preview (inline)
      "super-e m": "markdown::OpenPreview",
      // Markdown Preview (to the side)
      "super-e super-m": "markdown::OpenPreviewToTheSide",
    },
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-shift-o": null,
    },
  },
  // ───────────────────────────────────────────────
  // super-w  →  WINDOW
  // ───────────────────────────────────────────────
  {
    "context": "Workspace",
    "bindings": {
      "super-w": null,
      // Project Panel (Explorer)
      "super-w e": "project_panel::ToggleFocus",
      "super-w super-e": "project_panel::ToggleFocus",
      // Terminal
      "super-w t": "terminal_panel::Toggle",
      "super-w super-t": "terminal_panel::Toggle",
      // Outline Panel (persistent sidebar)
      "super-w o": "outline_panel::ToggleFocus",
      "super-w super-o": "outline_panel::ToggleFocus",
      // Git Panel
      "super-w g": "git_panel::ToggleFocus",
      "super-w super-g": "git_panel::ToggleFocus",
      // Debug Panel
      "super-w d": "debug_panel::ToggleFocus",
      "super-w super-d": "debug_panel::ToggleFocus",
      // AI Agent Panel
      "super-w a": "agent::ToggleFocus",
      "super-w super-a": "agent::ToggleFocus",
      // Diagnostics / problems
      "super-w m": "diagnostics::Deploy",
      "super-w super-m": "diagnostics::Deploy",
      // Toggle Left Dock
      "super-w h": "workspace::ToggleLeftDock",
      "super-w super-h": "workspace::ToggleLeftDock",
      // Toggle Right Dock
      "super-w l": "workspace::ToggleRightDock",
      "super-w super-l": "workspace::ToggleRightDock",
      // Toggle Bottom Dock
      "super-w j": "workspace::ToggleBottomDock",
      "super-w super-j": "workspace::ToggleBottomDock",
      // Toggle all docks (number key — no super-held variant needed)
      "super-w 0": "workspace::ToggleAllDocks",
      // Close the active dock
      "super-w x": "workspace::CloseActiveDock",
      "super-w super-x": "workspace::CloseActiveDock",
      // Recent Projects
      "super-w r": ["projects::OpenRecent", { "create_new_window": false }],
      "super-w super-r": [
        "projects::OpenRecent",
        { "create_new_window": true },
      ],
      // Remote projects
      "super-w c": [
        "projects::OpenRemote",
        { "from_existing_connection": false, "create_new_window": false },
      ],
      "super-w super-c": [
        "projects::OpenRemote",
        { "from_existing_connection": false, "create_new_window": true },
      ],
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "super-w x": ["pane::CloseActiveItem", { "close_pinned": false }],
      "super-w super-x": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },
]
